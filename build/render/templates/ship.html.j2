{% extends "base.html.j2" %}
{% block title %}{{ r.display }}{% endblock %}
{% block content %}
<h1>{{ r.display }}
    {% if r.tier %}<span class="tier tier-{{ r.tier }}">Tier {{ r.tier }}</span>{% endif %}
    <span class="obtain obtain-{% if r.player_obtainable %}craftable{% else %}npc{% endif %}">{% if r.player_obtainable %}Player ship{% else %}Enemy ship{% endif %}</span>
</h1>
<div class="id" style="margin-bottom:1rem">{{ r.identifier }}</div>

<div class="section-grid">
<div>

<h2>Class &amp; faction</h2>
<div class="kvs">
<dl>
    <dt>Class</dt><dd><strong>{{ r.class_label }}</strong> <span style="color:var(--text-faint)" class="mono">({{ r.class_raw or 'unknown' }})</span></dd>
    <dt>Faction</dt><dd>{{ r.faction|capitalize }}</dd>
    <dt>Category</dt><dd class="mono">{{ r.category }}</dd>
    {% if r.blueprint %}<dt>Blueprint</dt><dd class="mono">{{ r.blueprint }}</dd>{% endif %}
    {% if r.config_stem %}<dt>Config</dt><dd class="mono">data/configs/ships/{{ r.config_stem }}.cfg</dd>{% endif %}
</dl>
</div>

{% if not r.player_obtainable %}
<h2>AI scaling (enemy ship)</h2>
<p>The engine tunes pirate / ancients ship behaviour with these multipliers, applied on top of the underlying class stats.</p>
<div class="kvs">
<dl>
    {% if r.ai_damage_scale is not none %}<dt>Damage scale</dt><dd>×{{ r.ai_damage_scale }}</dd>{% endif %}
    {% if r.ai_speed_scale is not none %}<dt>Speed scale</dt><dd>×{{ r.ai_speed_scale }}</dd>{% endif %}
    {% if r.ai_turn_rate_scale is not none %}<dt>Turn rate scale</dt><dd>×{{ r.ai_turn_rate_scale }}</dd>{% endif %}
    {% if r.drop_loot %}<dt>Drops</dt><dd class="mono">{{ r.drop_loot }}</dd>{% endif %}
</dl>
</div>
{% endif %}

{% if r.player_obtainable %}
<h2>Buying / upgrading</h2>
<p>This is a <strong>{{ r.class_label }}-class</strong> ship. To upgrade it, craft components from the <code>V_{{ r.class_raw|replace('L0_','')|replace('L1_','')|replace('L2_','')|replace('L3_','')|replace('L4_','')|upper }}_*</code> recipe family (MK1 → MK5):</p>
<ul>
    <li><strong>Chassis</strong> — hull integrity; MK5 variants exist as named alts (e.g. Excalibur, Red Fury for Corvettes).</li>
    <li><strong>Cargo</strong> — inventory capacity in the ship's hold.</li>
    <li><strong>Shield</strong> — energy shield buffer before hull damage.</li>
    <li><strong>Engine</strong> (<code>SPACE_ENGINE</code>) — sublight / warp speed.</li>
</ul>
<p>You <em>cannot</em> transplant a Corvette component into a Frigate (or vice versa) — see the note on the <a href="{{ root }}ships.html">Ships overview</a>.</p>
{% endif %}

</div>

<aside class="infobox">
<h3 style="margin-top:0">At a glance</h3>
<dl>
    <dt>Class</dt><dd>{{ r.class_label }}</dd>
    <dt>Faction</dt><dd>{{ r.faction|capitalize }}</dd>
    {% if r.tier %}<dt>Tier</dt><dd>{{ r.tier }}</dd>{% endif %}
    {% if r.base_price %}<dt>Base price</dt><dd>{{ r.base_price }}</dd>{% endif %}
    {% if r.stack_size %}<dt>Stack</dt><dd>{{ r.stack_size }}</dd>{% endif %}
    {% if r.inv_frame is not none %}<dt>inv_frame</dt><dd class="mono">{{ r.inv_frame }}</dd>{% endif %}
    <dt>Owner</dt><dd>{% if r.player_obtainable %}Player obtainable{% else %}Enemy / NPC{% endif %}</dd>
</dl>
</aside>
</div>

<p style="margin-top:2.5rem"><a class="muted" href="{{ root }}ships.html">← Back to all ships</a></p>
{% endblock %}
