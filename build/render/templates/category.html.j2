{% extends "base.html.j2" %}
{% block title %}{{ title }}{% endblock %}
{% block content %}
<h1>{{ title }}</h1>
{% if intro %}<p>{{ intro }}</p>{% endif %}

<div class="controls">
    <input type="search" class="search" id="catSearch" placeholder="Filter {{ rows|length }} {{ category }}…" autocomplete="off">
    {% if tiers|length > 1 %}
    <div class="pills" id="tierPills">
        <span class="pill active" data-tier="all">All tiers</span>
        {% for t in tiers %}<span class="pill" data-tier="{{ t }}">T{{ t }}</span>{% endfor %}
    </div>
    {% endif %}
    {% if obtains and obtains|length > 1 %}
    <div class="pills" id="obtainPills">
        <span class="pill active" data-obtain="obtainable">Obtainable</span>
        {% for k in obtains %}<span class="pill" data-obtain="{{ k }}">{{ {'craftable':'Craftable','loot':'Loot','npc':'NPC','unobtainable':'Unobtainable'}[k] }}</span>{% endfor %}
        <span class="pill" data-obtain="all">Show all</span>
    </div>
    {% endif %}
</div>

<table class="wiki" id="catTable">
    <thead>
        <tr>
            <th class="icon"></th>
            <th data-key="display">Name</th>
            <th data-key="tier" class="numeric">Tier</th>
            <th data-key="identifier">Identifier</th>
            {% for col in extra_cols %}
            <th data-key="{{ col.key }}" {% if col.numeric %}class="numeric"{% endif %}>{{ col.label }}</th>
            {% endfor %}
        </tr>
    </thead>
    <tbody>
        {% for r in rows %}
        <tr data-tier="{{ r.tier }}"{% if r.obtain_kind %} data-obtain="{{ r.obtain_kind }}"{% endif %} data-search="{{ (r.display ~ ' ' ~ r.identifier ~ ' ' ~ (r.obtain_label or ''))|lower }}">
            <td class="icon">
                {% if r.icon %}<img src="{{ root }}{{ r.icon }}" alt="">{% else %}<div class="tier tier-{{ r.tier }}" style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:0.9rem">{{ r.display[:2]|upper }}</div>{% endif %}
            </td>
            <td><a href="{{ root }}{{ category }}/{{ r.slug }}.html">{{ r.display }}</a></td>
            <td class="numeric"><span class="tier tier-{{ r.tier }}">T{{ r.tier }}</span></td>
            <td class="mono">{{ r.identifier }}</td>
            {% for col in extra_cols %}
            <td {% if col.numeric %}class="numeric"{% endif %}{% if col.mono %} class="mono"{% endif %}>{{ r.get(col.key) if r.get(col.key) is not none else '' }}</td>
            {% endfor %}
        </tr>
        {% endfor %}
    </tbody>
</table>

{% if not rows %}<div class="empty">No entries in this category.</div>{% endif %}
{% endblock %}
{% block scripts %}
<script>
(function(){
    const table = document.getElementById('catTable');
    if(!table) return;
    const tbody = table.tBodies[0];
    const rows = Array.from(tbody.rows);
    const search = document.getElementById('catSearch');
    const tierPills = document.getElementById('tierPills');
    const obtainPills = document.getElementById('obtainPills');
    let tierFilter = 'all';
    // Only apply the obtainable-by-default filter when the page actually
    // surfaces obtainability pills; otherwise leave rows untouched (e.g.
    // Resources, Ores — categories where every entry is player-obtainable).
    let obtainFilter = obtainPills ? 'obtainable' : 'all';

    function apply(){
        const q = (search?.value || '').trim().toLowerCase();
        for(const r of rows){
            const matchQ = !q || r.dataset.search.indexOf(q) !== -1;
            const matchT = tierFilter === 'all' || r.dataset.tier === tierFilter;
            const kind = r.dataset.obtain;
            let matchO;
            if(obtainFilter === 'all') matchO = true;
            else if(obtainFilter === 'obtainable') matchO = kind === 'craftable' || kind === 'loot';
            else matchO = kind === obtainFilter;
            r.style.display = (matchQ && matchT && matchO) ? '' : 'none';
        }
    }
    search?.addEventListener('input', apply);
    function wirePills(el, attr, set){
        el?.addEventListener('click', e => {
            const p = e.target.closest('.pill');
            if(!p) return;
            el.querySelectorAll('.pill').forEach(x => x.classList.remove('active'));
            p.classList.add('active');
            set(p.dataset[attr]);
            apply();
        });
    }
    wirePills(tierPills, 'tier', v => tierFilter = v);
    wirePills(obtainPills, 'obtain', v => obtainFilter = v);
    apply();
})();
</script>
{% endblock %}
