{% extends "base.html.j2" %}
{% block title %}{{ r.display }}{% endblock %}
{% block content %}
<h1>{{ r.display }} <span class="obtain obtain-{% if r.team == 'PIRATES' %}loot{% elif r.team == 'ZOMBIES' %}npc{% else %}unobtainable{% endif %}">{{ r.team }}</span></h1>
<div class="id" style="margin-bottom:1rem">{{ r.identifier }}.cfg</div>

<div class="section-grid">
<div>

<h2>Stats</h2>
<div class="kvs">
<dl>
    <dt>Team</dt><dd>{{ r.team }}</dd>
    <dt>Life</dt><dd>{{ r.life }} HP</dd>
    {% if r.shield is not none %}<dt>Shield</dt><dd>{{ r.shield }}</dd>{% endif %}
    {% if r.walk_speed %}<dt>Walk speed</dt><dd>{{ r.walk_speed }}</dd>{% endif %}
    {% if r.sprint_mult %}<dt>Sprint mult.</dt><dd>×{{ r.sprint_mult }}</dd>{% endif %}
    {% if r.jump_height %}<dt>Jump height</dt><dd>{{ r.jump_height }}</dd>{% endif %}
    {% if r.scale %}<dt>Scale</dt><dd>{{ r.scale }}</dd>{% endif %}
    {% if r.weapon_display %}<dt>Weapon</dt><dd>{% if r.weapon_link %}<a href="{{ root }}{{ r.weapon_link }}">{{ r.weapon_display }}</a>{% else %}{{ r.weapon_display }}{% endif %}{% if r.weapon_type %} <span style="color:var(--text-faint)">({{ r.weapon_type }})</span>{% endif %}</dd>{% endif %}
    {% if r.ai_template %}<dt>AI</dt><dd class="mono">{{ r.ai_template }}</dd>{% endif %}
    {% if r.npc_type %}<dt>NPC type</dt><dd class="mono">{{ r.npc_type }}</dd>{% endif %}
    {% if r.skin %}<dt>Skin</dt><dd class="mono">{{ r.skin }}</dd>{% endif %}
</dl>
</div>

<h2>Drops</h2>
{% if r.drops %}
<p>From randomset <code>{{ r.drop_table_name }}</code>. Chance is the engine's raw <code>m_chance</code> (relative weight, not a literal percentage).</p>
<table class="wiki">
<thead><tr><th>Item</th><th class="numeric">Chance</th><th class="numeric">Count</th></tr></thead>
<tbody>
{% for d in r.drops %}
<tr>
    <td>{% if d.url %}<a href="{{ root }}{{ d.url }}">{{ d.display }}</a>{% else %}{{ d.display }}{% endif %}<br><span style="color:var(--text-faint);font-size:0.85em" class="mono">{{ d.identifier }}</span></td>
    <td class="numeric"><strong>{{ d.chance }}</strong></td>
    <td class="numeric">{% if d.min_count == d.max_count %}{{ d.min_count }}{% else %}{{ d.min_count }}–{{ d.max_count }}{% endif %}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% elif r.drop_table_name %}
<p style="color:var(--text-faint)">Drop table <code>{{ r.drop_table_name }}</code> referenced but not found in <code>data/configs/randomsets/</code>.</p>
{% else %}
<p style="color:var(--text-faint)">No drop table assigned in the character config.</p>
{% endif %}

<h2>Where you'll meet them</h2>
<ul>
{% if r.team == 'PIRATES' %}
    <li><strong>Pirate strongholds and patrols</strong> on lawless planets. Higher-tier pirates spawn deeper in systems flagged hostile.</li>
    <li><strong>Pirate ship engagements</strong> in space — boarders appear when you destroy the ship's shields.</li>
    <li>Density scales with system difficulty / story progression; lower-tier <em>newbie</em> variants (file prefix <code>n_</code>) replace mid-tier pirates in safer systems.</li>
{% elif r.team == 'ZOMBIES' %}
    <li><strong>Corrupted zones</strong> — biomes flagged Corruption, near corruption cores, on planets the dark fog has reached.</li>
    <li>Surface waves at night plus deeper underground packs near Glowing-ore veins.</li>
    <li>Elite variants (<code>_elite_</code>) appear in late-game systems and around bosses.</li>
{% endif %}
</ul>
</div>

<aside class="infobox">
<h3 style="margin-top:0">At a glance</h3>
<dl>
    <dt>Type</dt><dd>{{ r.team|capitalize }}</dd>
    <dt>HP</dt><dd>{{ r.life }}</dd>
    {% if r.weapon_display %}<dt>Carries</dt><dd>{{ r.weapon_display }}</dd>{% endif %}
    <dt>Drop table</dt><dd class="mono">{{ r.drop_table_name or '—' }}</dd>
    <dt>Drops</dt><dd>{{ r.drops|length }} possible items</dd>
</dl>
</aside>
</div>

<p style="margin-top:2.5rem"><a class="muted" href="{{ root }}enemies.html">← Back to all enemies</a></p>
{% endblock %}
