{% extends "base.html.j2" %}
{% block title %}{{ r.display }}{% endblock %}
{% block content %}
<h1>{{ r.display }}</h1>
<img src="{{ root }}assets/worlds/{{ r.slug }}.png" alt="{{ r.display }} palette banner" style="display:block;width:100%;max-width:100%;border-radius:6px;border:1px solid var(--border);image-rendering:pixelated;margin:0.6rem 0 1rem">
<p style="font-size:0.82em;color:var(--text-faint);margin-top:-0.4rem">Stylised banner using the world's voxel palette — not an in-game screenshot.</p>
{% if r.description %}<p style="font-size:1.05em;color:var(--text)">{{ r.description }}</p>{% endif %}

<div class="kvs" style="margin:1rem 0">
<dl>
    <dt>Biome set</dt><dd class="mono">{{ r.biomes_name }}</dd>
    <dt>Distribution</dt><dd class="mono">{{ r.distribution_name }}</dd>
    <dt>Biome regions</dt><dd>{{ r.biome_region_count }}</dd>
    <dt>Voxel layers</dt><dd>{{ r.layer_count }}</dd>
    <dt>Unique ores</dt><dd>{{ r.ore_summary_count }}</dd>
    {% if r.planets %}<dt>Known planets</dt><dd>{{ r.planets|join(', ') }}</dd>
    {% else %}<dt>Known planets</dt><dd><span style="color:var(--text-faint)">None confirmed — most planets pick biomes procedurally and can't be linked to a single world type from the static configs.</span></dd>{% endif %}
</dl>
</div>

<h2>Ores you can find here</h2>
<p>Aggregated from every layer in this world's distribution. Frequency is the sum across layers (higher = denser); vein size is the largest <code>m_extent</code> seen; deepest Y is the lowest <code>m_startY</code> a layer with this ore occupies (lower Y = closer to the planet core).</p>
{% if r.ore_summary %}
<table class="wiki">
<thead><tr><th>Voxel</th><th class="numeric">Layers</th><th class="numeric">Total freq</th><th class="numeric">Max vein</th><th class="numeric">Deepest Y</th></tr></thead>
<tbody>
{% for o in r.ore_summary %}
<tr>
    <td>{% if o.url %}<a href="{{ root }}{{ o.url }}">{{ o.voxel_name }}</a>{% else %}{{ o.voxel_name }}{% endif %}</td>
    <td class="numeric">{{ o.layer_count }}</td>
    <td class="numeric"><strong>{{ o.total_freq }}</strong></td>
    <td class="numeric">{{ o.max_extent if o.max_extent else '—' }}</td>
    <td class="numeric mono">{{ o.deepest_y }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% else %}
<p style="color:var(--text-faint)">No ore entries in this distribution.</p>
{% endif %}

<h2>Altitude profile</h2>
<p>Stylised slice of a planet — a mountain rising into the topmost band, the planet's interior below. <strong>Y is a radial coordinate from the planet's core</strong>, not altitude above sea level: Y 256 is the outermost rock shell, Y 0 is the core. The terrain heightmap carves into the outer shells, so anything near Y 256 is reachable by digging into a cliff or summit rather than going deep. That's why valuable voxels can show up in the very top band — they're "near the surface", just inside a peak. Hover an ore tile for its name and frequency; click to open the detail page.</p>
<div class="cross-section">
<svg class="cs-bg" viewBox="0 0 1000 800" preserveAspectRatio="none" aria-hidden="true">
    <defs>
        <linearGradient id="skyGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#1c2a4a"/>
            <stop offset="40%" stop-color="#3a4d6b"/>
            <stop offset="100%" stop-color="#5a6a82"/>
        </linearGradient>
        <linearGradient id="rockGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#4a3c2c"/>
            <stop offset="50%" stop-color="#2e2520"/>
            <stop offset="100%" stop-color="#16110d"/>
        </linearGradient>
        <linearGradient id="snowGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#f4f8ff"/>
            <stop offset="100%" stop-color="rgba(244,248,255,0)"/>
        </linearGradient>
    </defs>
    <!-- Sky -->
    <rect x="0" y="0" width="1000" height="220" fill="url(#skyGrad)"/>
    <!-- Distant haze hills -->
    <path d="M 0,200 L 100,180 L 200,195 L 320,170 L 420,185 L 540,165 L 660,190 L 780,175 L 900,195 L 1000,180 L 1000,220 L 0,220 Z"
          fill="rgba(40,32,28,0.55)"/>
    <!-- Foreground mountain -->
    <path d="M 0,220 L 80,210 L 140,195 L 210,165 L 270,140 L 320,105 L 370,75 L 420,45 L 470,20 L 520,30 L 565,60 L 615,95 L 670,130 L 730,160 L 790,180 L 860,195 L 930,210 L 1000,220 L 1000,800 L 0,800 Z"
          fill="url(#rockGrad)"/>
    <!-- Snow cap -->
    <path d="M 370,75 L 420,45 L 470,20 L 520,30 L 565,60 L 540,72 L 505,55 L 465,52 L 425,68 L 395,82 Z"
          fill="url(#snowGrad)"/>
    <!-- Horizon dashed line indicating plains level (Y≈200 boundary) -->
    <line x1="140" y1="218" x2="240" y2="218" stroke="rgba(255,255,255,0.35)" stroke-dasharray="6 5" stroke-width="1.2"/>
    <line x1="800" y1="218" x2="900" y2="218" stroke="rgba(255,255,255,0.35)" stroke-dasharray="6 5" stroke-width="1.2"/>
    <text x="248" y="222" fill="rgba(255,255,255,0.6)" font-family="ui-monospace, monospace" font-size="14">plains (Y≈200)</text>
    <text x="500" y="16" fill="rgba(255,255,255,0.75)" font-family="ui-monospace, monospace" font-size="14" text-anchor="middle">peak (Y≈256)</text>
</svg>
{% for layer in r.layers|sort(attribute='startY', reverse=True) %}
{% set ores = layer.ores|selectattr('frequency','gt',0)|list %}
<div class="cs-layer">
    <span class="cs-y">Y <strong>{{ layer.startY }}</strong>–<strong>{{ layer.endY }}</strong></span>
    <div class="cs-ores">
    {% for o in ores %}
        {% if o.url %}<a href="{{ root }}{{ o.url }}" class="cs-tile" title="{{ o.voxel_name }} · freq {{ o.frequency }}{% if o.extent %} · vein up to {{ o.extent }}{% endif %}">{% else %}<span class="cs-tile" title="{{ o.voxel_name }} · freq {{ o.frequency }}">{% endif %}
        {% if o.texture_url %}<img src="{{ root }}{{ o.texture_url }}" alt="{{ o.voxel_name }}">{% elif o.color %}<span class="swatch" style="background:rgb({{ o.color[0] }},{{ o.color[1] }},{{ o.color[2] }})"></span>{% else %}<span class="swatch"></span>{% endif %}
        {% if o.url %}</a>{% else %}</span>{% endif %}
    {% else %}
        <span class="cs-empty">no ore deposits</span>
    {% endfor %}
    </div>
</div>
{% endfor %}
</div>
{% if r.ore_summary %}
<details style="margin:0.6rem 0 0.4rem">
<summary style="cursor:pointer;color:var(--text-dim);font-size:0.9em">Legend — every ore this world spawns</summary>
<div class="cs-legend">
{% for o in r.ore_summary %}
{% if o.url %}<a href="{{ root }}{{ o.url }}" class="cs-tile cs-tile-labeled">{% else %}<span class="cs-tile cs-tile-labeled">{% endif %}
    {% if o.texture_url %}<img src="{{ root }}{{ o.texture_url }}" alt="{{ o.voxel_name }}">{% elif o.color %}<span class="swatch" style="background:rgb({{ o.color[0] }},{{ o.color[1] }},{{ o.color[2] }})"></span>{% endif %}
    <span class="cs-name">{{ o.voxel_name }}</span>
{% if o.url %}</a>{% else %}</span>{% endif %}
{% endfor %}
</div>
</details>
{% endif %}

<h2>Layer-by-layer breakdown</h2>
<p>Each layer is a Y band (radial distance from the planet's core). The engine fills the band with whatever's in <code>m_voxels</code> (stone-class blocks) plus <code>m_ores</code> entries (the rare resource nodes). Layers are listed top-down — Y 256 is the outermost rock shell (where mountain peaks reach), low Y is closer to the core.</p>

{% for layer in r.layers %}
<details {% if loop.first %}open{% endif %} style="background:var(--bg-card);border:1px solid var(--border);border-radius:6px;margin:0.6rem 0;padding:0">
<summary style="padding:0.7em 1em;cursor:pointer;font-family:ui-monospace,monospace;font-weight:600">
    Layer {{ layer.index }} · <span class="mono">Y {{ layer.startY }} … {{ layer.endY }}</span>
    <span style="color:var(--text-faint);font-weight:400;font-size:0.85em">
        ({{ (layer.voxels|length) }} voxel{% if layer.voxels|length != 1 %}s{% endif %}, {{ layer.ores|selectattr('frequency','gt',0)|list|length }} ore type{% if layer.ores|selectattr('frequency','gt',0)|list|length != 1 %}s{% endif %})
    </span>
</summary>
<div style="padding:0 1em 0.8em">

{% if layer.voxels %}
<h3 style="margin-top:0.8em">Voxels (terrain blocks)</h3>
<table class="wiki">
<thead><tr><th>Voxel</th><th class="numeric">Frequency</th></tr></thead>
<tbody>
{% for v in layer.voxels %}
<tr><td class="mono">{{ v.voxel_name }}</td><td class="numeric">{{ v.frequency }}</td></tr>
{% endfor %}
</tbody>
</table>
{% endif %}

{% set visible_ores = layer.ores|selectattr('frequency','gt',0)|list %}
{% if visible_ores %}
<h3>Ores (resource nodes)</h3>
<table class="wiki">
<thead><tr><th>Voxel</th><th class="numeric">Frequency</th><th class="numeric">Vein size</th></tr></thead>
<tbody>
{% for e in visible_ores %}
<tr>
    <td>{% if e.url %}<a href="{{ root }}{{ e.url }}">{{ e.voxel_name }}</a>{% else %}{{ e.voxel_name }}{% endif %}</td>
    <td class="numeric">{{ e.frequency }}</td>
    <td class="numeric">{{ e.extent if e.extent else '—' }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

</div>
</details>
{% endfor %}

<h2>Biome regions</h2>
<p>Biomes are picked at runtime by temperature × altitude. The same world type can host any of these climate-zone variants on any single planet.</p>
<table class="wiki">
<thead><tr><th>Biome</th><th class="numeric">Temp range (°)</th><th class="numeric">Altitude range</th></tr></thead>
<tbody>
{% for b in r.biome_regions %}
<tr>
    <td>{{ b.display }}<br><span style="color:var(--text-faint);font-size:0.85em" class="mono">{{ b.name }}</span></td>
    <td class="numeric mono">{{ b.startTemp }} … {{ b.endTemp }}</td>
    <td class="numeric mono">{{ b.startAlt }} … {{ b.endAlt }}</td>
</tr>
{% endfor %}
</tbody>
</table>

<p style="margin-top:2.5rem"><a class="muted" href="{{ root }}worlds.html">← Back to all worlds</a></p>
{% endblock %}
