<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ title }}{% endblock %} - Cubic Odyssey Wiki</title>
    <link rel="icon" type="image/svg+xml" href="{{ root }}assets/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ root }}assets/favicon-32.png">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ root }}assets/favicon-180.png">
    <link rel="shortcut icon" href="{{ root }}assets/favicon.ico">
    <link rel="stylesheet" href="{{ root }}assets/style.css">
</head>
<body>
<header class="site">
    <div class="inner">
        <div class="brand">
            <a href="{{ root }}index.html">Cubic Odyssey</a>
            <small>local wiki · {{ counts.total }} entries</small>
        </div>
        <nav>
            <a href="{{ root }}ores.html"      class="{% if category == 'ores' %}active{% endif %}">Ores</a>
            <a href="{{ root }}gems.html"      class="{% if category == 'gems' %}active{% endif %}">Gems</a>
            <a href="{{ root }}ingots.html"    class="{% if category == 'ingots' %}active{% endif %}">Ingots</a>
            <a href="{{ root }}tools.html"     class="{% if category == 'tools' %}active{% endif %}">Tools</a>
            <a href="{{ root }}weapons.html"   class="{% if category == 'weapons' %}active{% endif %}">Weapons</a>
            <a href="{{ root }}blocks.html"    class="{% if category == 'blocks' %}active{% endif %}">Blocks</a>
            <a href="{{ root }}resources.html" class="{% if category == 'resources' %}active{% endif %}">Resources</a>
            <a href="{{ root }}worlds.html"    class="{% if category == 'worlds' %}active{% endif %}">Worlds</a>
            <a href="{{ root }}enemies.html"   class="{% if category == 'enemies' %}active{% endif %}">Enemies</a>
            <a href="{{ root }}ships.html"     class="{% if category == 'ships' %}active{% endif %}">Ships</a>
            <a href="{{ root }}speeders.html"  class="{% if category == 'speeders' %}active{% endif %}">Speeders</a>
            <a href="{{ root }}guides.html"    class="{% if category == 'guides' %}active{% endif %}">Guides</a>
        </nav>
    </div>
</header>
<main class="wrap">
    {% block content %}{% endblock %}
</main>
<footer class="site">
    <div class="inner">
        Generated {{ build_time }} from game data ({{ game_version }}).
        Item names humanized from <code>STR_*</code> tokens; binary <code>.str</code> localization not yet decoded.
        Planet→biome distribution mapping is best-effort.
    </div>
</footer>
{% block scripts %}{% endblock %}
<script>
(function(){
    // Click any <th data-key> on a wiki table to sort by that column.
    // Numeric columns (th class="numeric") parse the cell text as a number;
    // unparseable cells sink to the bottom on ascending sort.
    document.querySelectorAll('table.wiki').forEach(table => {
        const headers = table.querySelectorAll('thead th[data-key]');
        if (!headers.length) return;
        const tbody = table.tBodies[0];
        if (!tbody) return;
        headers.forEach(th => {
            th.style.cursor = 'pointer';
            th.addEventListener('click', () => {
                const asc = !th.classList.contains('sort-asc');
                table.querySelectorAll('thead th').forEach(x =>
                    x.classList.remove('sort-asc', 'sort-desc'));
                th.classList.add(asc ? 'sort-asc' : 'sort-desc');
                const idx = th.cellIndex;
                const numeric = th.classList.contains('numeric');
                const sorted = Array.from(tbody.rows).sort((a, b) => {
                    const av = (a.cells[idx]?.textContent || '').trim();
                    const bv = (b.cells[idx]?.textContent || '').trim();
                    if (numeric) {
                        const an = parseFloat(av.replace(/[^\d.\-]/g, ''));
                        const bn = parseFloat(bv.replace(/[^\d.\-]/g, ''));
                        const aN = isNaN(an) ? Infinity : an;
                        const bN = isNaN(bn) ? Infinity : bn;
                        return asc ? aN - bN : bN - aN;
                    }
                    return asc ? av.localeCompare(bv) : bv.localeCompare(av);
                });
                sorted.forEach(r => tbody.appendChild(r));
            });
        });
    });
})();
</script>
</body>
</html>
