{% extends "base.html.j2" %}
{% block title %}{{ r.display }}{% endblock %}
{% block content %}
<div class="detail-head">
    {% if r.icon %}<div class="icon-big"><img src="{{ root }}{{ r.icon }}" alt=""></div>
    {% else %}<div class="icon-big placeholder">{{ r.display[:2]|upper }}</div>{% endif %}
    <div class="meta">
        <h1>{{ r.display }} <span class="tier tier-{{ r.tier }}">Tier {{ r.tier }}</span>{% if r.is_glowing %} <span class="tier tier-7">Glowing</span>{% endif %}</h1>
        <div class="id">{{ r.identifier }}</div>
        {% if r.color %}<div class="id" style="margin-top:0.4em"><span class="swatch" style="background: rgb({{ r.color[0] }},{{ r.color[1] }},{{ r.color[2] }});width:12px;height:12px;display:inline-block;border:1px solid var(--border);border-radius:2px;margin-right:0.4em;vertical-align:-2px"></span>Block colour rgb({{ r.color[0] }}, {{ r.color[1] }}, {{ r.color[2] }})</div>{% endif %}
        <p class="desc">Mineable {{ 'Glowing ' if r.is_glowing else '' }}ore block.{% if r.voxel_name %} Source voxel: <code>{{ r.voxel_name }}</code>.{% endif %}</p>
    </div>
</div>

<div class="section-grid">
<div>

<h2>Mining</h2>
<div class="kvs">
<dl>
    <dt>Tier</dt><dd>{{ r.tier }} (block category <code>E_VCAT_ORES</code>)</dd>
    {% if r.mine_unit is not none %}<dt>Block hardness</dt><dd>{{ r.mine_unit }} <span style="color:var(--text-faint)">(<code>m_mineUnit</code>; lower = faster)</span></dd>{% endif %}
    <dt>Required mining tool</dt>
    <dd>
        {% if r.required_laser_file %}
            <a href="{{ root }}tools/{{ r.required_laser|replace('.', '_') }}.html"><strong>{{ r.required_laser_file|replace('_', ' ')|title }}</strong></a>
            <span style="color:var(--text-faint)">(or any laser with voxel_tier ≥ {{ r.tier }})</span>
        {% else %}
            <span style="color:var(--text-faint)">No standard mining laser covers this tier.</span>
        {% endif %}
    </dd>
</dl>
</div>

{% if r.smelt %}
<h2>Smelting</h2>
<div class="kvs">
<dl>
    <dt>Result</dt>
    <dd>
        {% if r.ingot_identifier %}
            <a href="{{ root }}ingots/{{ r.ingot_identifier|replace('.', '_') }}.html">{{ ingot_displays.get(r.ingot_identifier, r.ingot_identifier) }}</a>
        {% else %}—{% endif %}
        × {{ r.smelt.qty }}
    </dd>
    <dt>Cook time</dt><dd>{{ r.smelt.cookTime }} s</dd>
    <dt>Fuel needed</dt><dd>{{ r.smelt.fuelNeeded }}</dd>
</dl>
</div>
{% endif %}

{% if r.is_glowing %}
<h2>What it's used for</h2>
<p>Glowing ores aren't used directly in crafting — they're an intermediate.{% if r.ingot_identifier %} The flow is always: <strong>mine&nbsp;→ smelt&nbsp;→ craft</strong>.{% endif %}</p>
<ol style="margin-top:0.5em">
    <li><strong>Mine</strong> the voxel with a tier-7 mining laser (Mining Laser 6 or 7). Lower-tier lasers do nothing to it.</li>
    {% if r.ingot_identifier %}
    <li><strong>Smelt</strong> in a furnace ({{ r.smelt.cookTime }}s, {{ r.smelt.fuelNeeded }} fuel) into <a href="{{ root }}ingots/{{ r.ingot_identifier|replace('.', '_') }}.html">{{ ingot_displays.get(r.ingot_identifier, r.ingot_identifier) }}</a>.</li>
    <li><strong>Craft</strong>:{% if r.ingot_uses_total %} the ingot is a crafting input for <strong>{{ r.ingot_uses_total }} recipe{{ 's' if r.ingot_uses_total != 1 else '' }}</strong> across high-tier weapons, ship parts, and gear.{% else %} no recipe in the current build consumes this ingot — keep it for now; future recipes may.{% endif %}</li>
    {% endif %}
</ol>

{% if r.ingot_uses_top %}
<p style="margin-top:1em;margin-bottom:0.4em"><strong>Top crafts that consume {{ ingot_displays.get(r.ingot_identifier, 'this ingot') }}</strong> (sorted by quantity per craft):</p>
<table class="wiki">
<thead><tr><th>Crafts</th><th class="numeric">Qty</th><th class="numeric">Skill</th></tr></thead>
<tbody>
{% for u in r.ingot_uses_top %}
<tr>
    <td>{% if u.crafted_url %}<a href="{{ root }}{{ u.crafted_url }}">{{ u.crafted_display }}</a>{% else %}{{ u.crafted_display }}{% endif %}</td>
    <td class="numeric"><strong>{{ u.qty }}</strong></td>
    <td class="numeric">{% if u.skill_type and u.skill_level is not none %}{{ u.skill_type }}@{{ u.skill_level }}{% else %}—{% endif %}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% if r.ingot_uses_total > r.ingot_uses_top|length %}<p style="font-size:0.85em;color:var(--text-faint);margin-top:0.4em">Showing top {{ r.ingot_uses_top|length }} of {{ r.ingot_uses_total }} recipes.</p>{% endif %}
{% endif %}

<p style="margin-top:1em"><strong>Tip:</strong> there's a craftable <em>Glowing Ore Extractor</em> deployable (tier&nbsp;5, requires <code>CRAFTING&nbsp;16</code>) that processes glowing ores in bulk. It costs 10 Gem Plates, 5 Super Conductors, plus 8 each of <a href="{{ root }}resources/res_rare_antimatter_cell.html">Antimatter</a>, <a href="{{ root }}resources/res_rare_darkmatter_cell.html">Dark Matter</a>, and <a href="{{ root }}resources/res_rare_gammamatter_cell.html">Gamma Matter</a> Cells — so don't try to craft it before you've mined a healthy stockpile of tier-6 Matter ores.</p>

<p style="margin-top:0.6em"><strong>Selling angle:</strong> the raw ore sells for {{ r.base_price }} qubits each with positive vendor demand (base_demand&nbsp;0.5). Smelting first roughly halves the inventory volume and lifts the per-unit value — sell ingots, not raw ore.</p>
{% endif %}

<h2>Where to find</h2>
{% if r.locations %}
<table class="wiki">
<thead><tr><th>World type</th><th>Layer Y</th><th class="numeric">Freq.</th><th class="numeric">Vein size</th><th>Planets (known)</th></tr></thead>
<tbody>
{% for loc in r.locations_grouped %}
<tr>
    <td><strong>{% if loc.world_slug %}<a href="{{ root }}worlds/{{ loc.world_slug }}.html">{{ loc.label }}</a>{% else %}{{ loc.label }}{% endif %}</strong><br><span style="color:var(--text-faint);font-size:0.85em">{{ loc.short }}</span></td>
    <td class="mono">{{ loc.y_start }} … {{ loc.y_end }}</td>
    <td class="numeric">{{ loc.frequency }}</td>
    <td class="numeric">{{ loc.extent if loc.extent else '—' }}</td>
    <td>{% if loc.planets %}{{ loc.planets|join(', ') }}{% else %}<span style="color:var(--text-faint)">(procedural — biome dependent)</span>{% endif %}</td>
</tr>
{% endfor %}
</tbody>
</table>
<p style="color:var(--text-faint);font-size:0.85em;margin-top:0.4em">Frequency / vein size are raw values from <code>data/configs/voxeldistributions/</code>. Higher frequency means more ore nodes per layer.</p>
{% else %}
<p style="color:var(--text-faint)">No layer entries found in voxel distribution files{% if r.is_glowing %} — Glowing variants may spawn via item drops, special biomes, or quest events rather than as world ore deposits.{% else %} for this ore.{% endif %}</p>
{% endif %}

</div>

<aside class="infobox">
<h3 style="margin-top:0">Item info</h3>
<dl>
    {% if r.stack_size %}<dt>Stack size</dt><dd>{{ r.stack_size }}</dd>{% endif %}
    {% if r.base_price is not none %}<dt>Base price</dt><dd>{{ r.base_price }}</dd>{% endif %}
    {% if r.recycle_value is not none %}<dt>Recycle</dt><dd>{{ r.recycle_value }}</dd>{% endif %}
    {% if r.voxel_name %}<dt>Voxel</dt><dd class="mono">{{ r.voxel_name }}</dd>{% endif %}
    {% if r.inv_frame is not none %}<dt>inv_frame</dt><dd class="mono">{{ r.inv_frame }}</dd>{% endif %}
    {% if r.description_string %}<dt>desc_id</dt><dd class="mono">{{ r.description_string }}</dd>{% endif %}
</dl>
</aside>
</div>

<p style="margin-top:2.5rem"><a class="muted" href="{{ root }}ores.html">← Back to all ores</a></p>
{% endblock %}
