{% extends "base.html.j2" %}
{% block title %}{{ r.display }}{% endblock %}
{% block content %}
<div class="detail-head">
    {% if r.icon %}<div class="icon-big"><img src="{{ root }}{{ r.icon }}" alt=""></div>
    {% else %}<div class="icon-big placeholder">{{ r.display[:2]|upper }}</div>{% endif %}
    <div class="meta">
        <h1>{{ r.display }} <span class="tier tier-{{ r.tier }}">Tier {{ r.tier }}</span></h1>
        <div class="id">{{ r.identifier }}</div>
        <p class="desc">{{ r.subtype_label or 'Utility / tool item.' }}</p>
    </div>
</div>

<div class="section-grid">
<div>

{% if r.weapon_stats %}
<h2>Tool stats</h2>
<div class="kvs">
<dl>
    {% if r.weapon_stats.get('voxel_tier') is not none %}<dt>Voxel tier</dt><dd>{{ r.weapon_stats.voxel_tier }} (can mine ore tiers ≤ {{ r.weapon_stats.voxel_tier }})</dd>{% endif %}
    {% if r.weapon_stats.get('voxel_damage') is not none %}<dt>Voxel damage</dt><dd>{{ r.weapon_stats.voxel_damage }}</dd>{% endif %}
    {% if r.weapon_stats.get('damageMin') is not none %}<dt>Damage (min/max)</dt><dd>{{ r.weapon_stats.damageMin }} / {{ r.weapon_stats.damageMax }}</dd>{% endif %}
    {% if r.weapon_stats.get('fireRateRPM') is not none %}<dt>Fire rate</dt><dd>{{ r.weapon_stats.fireRateRPM }} RPM</dd>{% endif %}
    {% if r.weapon_stats.get('energy_cost') is not none %}<dt>Energy / shot</dt><dd>{{ r.weapon_stats.energy_cost }}</dd>{% endif %}
    {% if r.weapon_stats.get('ammo_type') %}<dt>Ammo</dt><dd class="mono">{{ r.weapon_stats.ammo_type }}</dd>{% endif %}
    {% if r.weapon_stats.get('ray_length') is not none %}<dt>Ray length</dt><dd>{{ r.weapon_stats.ray_length }} m</dd>{% endif %}
    {% if r.weapon_stats.get('projectile_speed') is not none %}<dt>Projectile speed</dt><dd>{{ r.weapon_stats.projectile_speed }}</dd>{% endif %}
    {% if r.weapon_stats.get('explosionRange') is not none and r.weapon_stats.explosionRange > 0 %}<dt>Explosion range</dt><dd>{{ r.weapon_stats.explosionRange }}</dd>{% endif %}
</dl>
</div>
{% endif %}

{% if r.mines_ores %}
<h2>Mines</h2>
<table class="wiki">
<thead><tr><th class="icon"></th><th>Ore</th><th class="numeric">Tier</th></tr></thead>
<tbody>
{% for o in r.mines_ores %}
<tr>
    <td class="icon">{% if o.icon %}<img src="{{ root }}{{ o.icon }}" alt="">{% endif %}</td>
    <td><a href="{{ root }}ores/{{ o.slug }}.html">{{ o.display }}</a></td>
    <td class="numeric"><span class="tier tier-{{ o.tier }}">T{{ o.tier }}</span></td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

</div>

<aside class="infobox">
<h3 style="margin-top:0">Item info</h3>
<dl>
    <dt>Type</dt><dd class="mono">{{ r.type }}</dd>
    {% if r.durability is not none %}<dt>Durability</dt><dd>{{ r.durability }}</dd>{% endif %}
    {% if r.stack_size %}<dt>Stack size</dt><dd>{{ r.stack_size }}</dd>{% endif %}
    {% if r.base_price is not none %}<dt>Base price</dt><dd>{{ r.base_price }}</dd>{% endif %}
    {% if r.recycle_value is not none %}<dt>Recycle</dt><dd>{{ r.recycle_value }}</dd>{% endif %}
    {% if r.inv_frame is not none %}<dt>inv_frame</dt><dd class="mono">{{ r.inv_frame }}</dd>{% endif %}
</dl>
</aside>
</div>

<p style="margin-top:2.5rem"><a class="muted" href="{{ root }}tools.html">← Back to all tools</a></p>
{% endblock %}
