{% extends "base.html.j2" %}
{% block title %}{{ r.display }}{% endblock %}
{% block content %}
<div class="detail-head">
    {% if r.icon %}<div class="icon-big"><img src="{{ root }}{{ r.icon }}" alt=""></div>
    {% else %}<div class="icon-big placeholder">{{ r.display[:2]|upper }}</div>{% endif %}
    <div class="meta">
        <h1>{{ r.display }} <span class="tier tier-{{ r.tier }}">Tier {{ r.tier }}</span></h1>
        <div class="id">{{ r.identifier }}</div>
        <p class="desc">Smelted ingot. Crafting input for tools, weapons, ship parts.</p>
    </div>
</div>

<div class="section-grid">
<div>

{% if r.smelted_from %}
<h2>Smelted from</h2>
<div class="kvs">
<dl>
    <dt>Source ore</dt>
    <dd><a href="{{ root }}ores/{{ r.smelted_from.slug }}.html">{{ r.smelted_from.display }}</a> <span class="tier tier-{{ r.smelted_from.tier }}">T{{ r.smelted_from.tier }}</span></dd>
    <dt>Cook time</dt><dd>{{ r.smelt.cookTime }} s</dd>
    <dt>Fuel needed</dt><dd>{{ r.smelt.fuelNeeded }}</dd>
    <dt>Yield</dt><dd>×{{ r.smelt.qty }} per ore</dd>
</dl>
</div>
{% else %}
<h2>Smelted from</h2>
<p style="color:var(--text-faint)">Source ore not resolvable from furnace recipes.</p>
{% endif %}

</div>

<aside class="infobox">
<h3 style="margin-top:0">Item info</h3>
<dl>
    <dt>Type</dt><dd class="mono">{{ r.type }}</dd>
    {% if r.stack_size %}<dt>Stack size</dt><dd>{{ r.stack_size }}</dd>{% endif %}
    {% if r.base_price is not none %}<dt>Base price</dt><dd>{{ r.base_price }}</dd>{% endif %}
    {% if r.recycle_value is not none %}<dt>Recycle</dt><dd>{{ r.recycle_value }}</dd>{% endif %}
    {% if r.inv_frame is not none %}<dt>inv_frame</dt><dd class="mono">{{ r.inv_frame }}</dd>{% endif %}
</dl>
</aside>
</div>

<p style="margin-top:2.5rem"><a class="muted" href="{{ root }}ingots.html">← Back to all ingots</a></p>
{% endblock %}
